{
  "name": "openelinaro",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "bun src/cli/bootstrap.ts",
    "setup:python": "bun src/cli/setup-python.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "demo": "bun src/demo.ts",
    "check": "tsc --noEmit && tsc --noEmit --project web/finance/tsconfig.json",
    "finance:api": "bun web/finance/server.ts",
    "finance:dev": "vite --config web/finance/vite.config.ts",
    "finance:build": "vite build --config web/finance/vite.config.ts",
    "finance:preview": "vite preview --config web/finance/vite.config.ts",
    "test": "bun test $(find src -name '*.test.ts' ! -name '*.e2e.test.ts')",
    "test:unit": "bun test $(find src -name '*.test.ts' ! -name '*.e2e.test.ts')",
    "test:e2e": "bun test $(find src -name '*.e2e.test.ts' ! -name '*.paid.e2e.test.ts')",
    "test:e2e:paid": "bun test $(find src -name '*.paid.e2e.test.ts')",
    "test:all": "bun test src/**/*.test.ts",
    "test:openbrowser:e2e": "bun test src/services/openbrowser-agent.e2e.test.ts",
    "telemetry:audit": "bun scripts/telemetry-audit.ts",
    "benchmark:memory:longmemeval": "bun src/cli/longmemeval-memory-benchmark.ts",
    "benchmark:swebench:verified:difficulty": "bun src/cli/swebench-verified-difficulty-analysis.ts",
    "docs:index": "bun src/cli/docs-index.ts",
    "service:healthcheck": "bun src/cli/healthcheck.ts",
    "secret": "bun src/cli/secrets.ts",
    "secret:import-card": "./scripts/import-payment-card.sh",
    "service:install": "./scripts/service-install.sh",
    "service:prepare-update": "./scripts/service-prepare-update.sh",
    "service:update-detached": "./scripts/service-update-detached.sh",
    "service:update": "./scripts/service-update.sh",
    "service:rollback-detached": "./scripts/service-rollback-detached.sh",
    "service:rollback": "./scripts/service-rollback.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@google/genai": "1.44.0",
    "@langchain/core": "^1.1.32",
    "@mariozechner/pi-ai": "0.58.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.116",
    "discord.js": "^14.25.1",
    "imapflow": "^1.2.16",
    "nodemailer": "^8.0.3",
    "postal-mime": "^2.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
